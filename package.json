{
  "name": "learn-bot-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "postinstall": "pnpm --filter @learn-bot/web prisma:generate",
    "dev": "pnpm dev:desktop",
    "dev:desktop": "pnpm --filter @learn-bot/desktop dev",
    "dev:legacy-web": "pnpm --filter @learn-bot/web dev",
    "build": "pnpm build:desktop",
    "build:desktop": "pnpm --filter @learn-bot/desktop build",
    "build:legacy-web": "pnpm --filter @learn-bot/web build",
    "lint": "pnpm lint:desktop",
    "lint:desktop": "pnpm exec eslint apps/desktop --config eslint.config.mjs && pnpm lint:boundaries",
    "lint:boundaries": "pnpm exec eslint packages/ui apps/desktop",
    "lint:legacy-web": "pnpm --filter @learn-bot/web lint",
    "test": "pnpm test:web",
    "test:web": "pnpm --filter @learn-bot/web test",
    "test:e2e": "pnpm --filter @learn-bot/web test:e2e",
    "prisma:generate": "pnpm --filter @learn-bot/web prisma:generate",
    "prisma:push": "pnpm --filter @learn-bot/web prisma:push"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "electron": "^41.2.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  }
}
